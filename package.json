{
  "name": "ozbys-node-pubsub",
  "private": true,
  "type": "module",
  "imports": {
    "#generated/*": "./.webpresso/generated/*"
  },
  "scripts": {
    "act:ci": "bun ./scripts/act-with-doppler.ts push -W .github/workflows/ci.yml",
    "act:cleanup": "bun ./scripts/act-with-doppler.ts workflow_dispatch -W .github/workflows/cleanup-stale-neon-e2e-branches.yml -j cleanup",
    "act:e2e": "bun ./scripts/act-with-doppler.ts workflow_dispatch -W .github/workflows/testing-e2e-act.yml -j full-suite-local",
    "act:list": "bun ./scripts/act-with-doppler.ts -l",
    "build": "vp run build",
    "catalog:check": "pnpm exec webpresso agent audit catalog-drift",
    "check": "vp check",
    "clean": "vp run clean",
    "client:bundle:check": "pnpm exec webpresso agent audit bundle-budget apps/client/dist --max-js-asset-bytes 512000 --max-html-eager-js-asset-bytes 262144 --max-html-eager-js-total-bytes 393216",
    "dev": "with-secrets --doppler ozby-shell:dev -- vp run dev",
    "dev:no-doppler": "vp run dev",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp run lint",
    "lint:repo": "oxlint .",
    "test": "vp run test",
    "check-types": "vp run check-types",
    "commitlint": "commitlint",
    "secretlint": "secretlint",
    "setup:agent-kit": "pnpm exec webpresso agent setup --yes --with omx,gstack",
    "postinstall": "pnpm run setup:agent-kit",
    "prepare": "husky",
    "docs:check": "pnpm exec webpresso agent audit docs-frontmatter",
    "blueprints:check": "pnpm exec webpresso agent audit blueprint-lifecycle --legacy-omx",
    "e2e": "bun ./apps/e2e/scripts/e2e-with-neon.ts",
    "ai:eval": "bun ./scripts/run-mapping-eval.ts",
    "probes:lab": "bun scripts/probes/consistency-lab/run-all.ts"
  },
  "dependencies": {
    "@webpresso/cli": "link:../../webpresso/monorepo/packages/cli/public-cli"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.0",
    "@types/react": "catalog:",
    "@webpresso/agent-kit": "catalog:",
    "@webpresso/runtime": "catalog:",
    "@webpresso/schema-engine": "catalog:",
    "@webpresso/schema-frontend": "catalog:",
    "@webpresso/schema-loaders": "catalog:",
    "@webpresso/schema-spec": "catalog:",
    "@webpresso/stryker-config": "catalog:",
    "@webpresso/typescript-config": "catalog:",
    "@webpresso/vitest-config": "catalog:",
    "@webpresso/webpresso": "catalog:",
    "husky": "catalog:",
    "oxlint": "catalog:tooling",
    "react": "catalog:",
    "secretlint": "^9.3.0",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@commitlint/config-validator>ajv": "8.18.0",
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "@secretlint/config-loader>ajv": "8.18.0",
      "@textlint/linter-formatter>js-yaml": "3.14.2",
      "@textlint/linter-formatter>lodash": "4.18.1",
      "@voidzero-dev/vite-plus-core>yaml": "2.8.3",
      "micromatch>picomatch": "2.3.2",
      "protobufjs": "7.5.5",
      "table>ajv": "8.18.0",
      "@webpresso/webpresso": "link:../../webpresso/webpresso"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite>esbuild": "*"
      }
    },
    "onlyBuiltDependencies": [
      "@webpresso/agent-kit",
      "@webpresso/db-branching",
      "@webpresso/neon-branching",
      "@webpresso/runtime",
      "@webpresso/vitest-config",
      "@webpresso/workers-test-kit"
    ]
  }
}
