{
  "extends": "@webpresso/agent-tsconfig/react-router.json",
  "compilerOptions": {
    "types": ["vite/client", "node"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"],
      "@repo/ui/components": ["../../packages/ui/src/components/index.tsx"],
      "@repo/ui/lib": ["../../packages/ui/src/lib/index.tsx"]
    },
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src", "../../packages/ui/src"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
